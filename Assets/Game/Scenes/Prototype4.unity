  itemId: p4_withy
  playerKnowerId: p3_player
  displayName: A Cut Withy
  description: A willow rod left by the bed's edge, still green enough to bend double.
  propertyIds:
  - binds_fast
  - split_prone
  autoRevealOnTake: 1
  revealLine: Withy. It bends, it binds. And split with the grain, it makes two.
  unrevealedTakeLine: Taken. There's more to it than you can say yet.
  attendDuration: 1
