  itemId: p4_alder_billet
  playerKnowerId: p3_player
  displayName: An Alder Billet
  description: Split wood, stacked against a dark wall and half forgotten.
  propertyIds:
  - burns_slow
  autoRevealOnTake: 1
  revealLine: Alder. It doesn't blaze, it smolders. Smoke you could hang a season's
    catch in.
  unrevealedTakeLine: Taken. There's more to it than you can say yet.
  attendDuration: 1
