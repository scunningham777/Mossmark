  m_Name:
  m_EditorClassIdentifier: Assembly-CSharp::Mossmark.Prototype3.PropertyPickupAttendable
  itemId: p4_char_knot
  playerKnowerId: p3_player
  displayName: A Char Knot
  description: A knot of charcoal fallen from someone's load, edges like broken glass.
  propertyIds:
  - burns_slow
  autoRevealOnTake: 1
  revealLine: Charcoal. Feather-light, bone-black. A fire that agreed to wait.
  unrevealedTakeLine: Taken. There's more to it than you can say yet.
  attendDuration: 1
