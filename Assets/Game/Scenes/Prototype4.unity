--- !u!114 &3200007
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 3200001}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2ea6422d1962ba3409655b2a2dc99dff, type: 3}
  m_Name:
  m_EditorClassIdentifier: Assembly-CSharp::Mossmark.Prototype4.AcquaintableAttendable
  entityId: p4_osier_bed
  unfamiliarShortName: A stand of growth
  unfamiliarDescription: A stand of growth along the water, too even to be wild.
    Someone's hand in it, sometime or other.
  unfamiliarTint: {r: 0.45, g: 0.45, b: 0.45, a: 1}
  unfamiliarInteractionLine: Hold E to walk the ground
  seededPropertyIds:
  - binds_fast
  seededKnowledgeLead: The willows here are known for
  trueStateNote: coppiced on a three-year turn for the netmender's withies; north
    side ready this year
  acquaintanceStages:
  - stageId: acquainted
    stageDisplayName: Acquainted
    attendsCost: 2
    shortName: An osier bed
    description: An osier bed. Willow, cut and come again. The stools are old and
      the rods are young, and someone crops it in turns.
    tint: {r: 0.5, g: 0.58, b: 0.4, a: 1}
    interactionLine: Hold E to walk the rows
    attendFlavors:
    - Cut low, grown tall, cut low again. The rhythm of it is everywhere once you
      see it.
  - stageId: known
    stageDisplayName: Known
    attendsCost: 3
    shortName: The Osier Bed
    description: The osier bed, coppiced on a three-year turn for as long as the
      netmender has needed withies. The north side is this year's, rods straight
      as a wish and ready for cutting.
    tint: {r: 0.42, g: 0.68, b: 0.38, a: 1}
    interactionLine: Hold E to linger among the willows
    attendFlavors:
    - A moorhen picks its way between the stools like it owns them.
    - The cut stumps bead with sap. The bed is never done, only resting.
  attendDuration: 2
  unfamiliarAttendFlavors:
  - You walk the edge of it. Even rows, or nearly. It keeps whatever it knows.
